# Auto-apply --legacy-peer-deps so plain `npm install` works.
#
# Without this, npm 7+ refuses to install because
# @tanstack/eslint-plugin-query@5.101.0 (resolved from "^5.27.7")
# declares a peer of typescript@^5.4.0 || ^6.0.0 while the project
# pins typescript@5.2.2. The peer is dev-only (lint plugin) and the
# runtime build doesn't care, so we follow the README's documented
# `npm install --legacy-peer-deps` invocation implicitly.
legacy-peer-deps=true
